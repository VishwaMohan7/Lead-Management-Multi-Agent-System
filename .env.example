# Nvidia Nemotron API Configuration
# Required for running the FastAPI app. Tests use the mock model automatically.

# Nvidia API Key from build.nvidia.com
NVIDIA_API_KEY=

# Swappable model, defaults to nvidia/nemotron-3-nano-omni-30b-a3b-reasoning
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Swappable base URL, defaults to https://integrate.api.nvidia.com/v1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
